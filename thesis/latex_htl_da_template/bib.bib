author = {Zivkovic, Zoran},
doi = {10.1109/ICPR.2004.1333992},
issn = {10514651},
journal = {Proceedings - International Conference on Pattern Recognition},
pages = {28--31},
publisher = {Institute of Electrical and Electronics Engineers Inc.},
title = {{Improved adaptive Gaussian mixture model for background subtraction}},
volume = {2},
year = {2004}
}
@article{Gustafsson2014,
abstract = {In this study we revisit the problem of computing steady Navier-Stokes flows in two-dimensional unbounded domains. Precise quantitative characterization of such flows in the high-Reynolds number limit remains an open problem of theoretical fluid dynamics. Following a review of key mathematical properties of such solutions related to the slow decay of the velocity field at large distances from the obstacle, we develop and carefully validate a spectrally-accurate computational approach which ensures the correct behavior of the solution at infinity. In the proposed method the numerical solution is defined on the entire unbounded domain without the need to truncate this domain to a finite box with some artificial boundary conditions prescribed at its boundaries. Since our approach relies on the streamfunction-vorticity formulation, the main complication is the presence of a discontinuity in the streamfunction field at infinity which is related to the slow decay of this field. We demonstrate how this difficulty can be overcome by reformulating the problem using a suitable background "skeleton" field expressed in terms of the corresponding Oseen flow combined with spectral filtering. The method is thoroughly validated for Reynolds numbers spanning two orders of magnitude with the results comparing favourably against known theoretical predictions and the data available in the literature.},
archivePrefix = {arXiv},
arxivId = {1407.1731},
author = {Gustafsson, Jonathan and Protas, Bartosz},
eprint = {1407.1731},
file = {:home/luca/.var/app/com.elsevier.MendeleyDesktop/data/data/Mendeley Ltd./Mendeley Desktop/Downloaded/Gustafsson, Protas - 2014 - Computation of Steady Incompressible Flows in Unbounded Domains.pdf:pdf},
keywords = {Steady Navier-Stokes system,spectral methods,unbounded domains,wake flows},
month = {jul},
title = {{Computation of Steady Incompressible Flows in Unbounded Domains}},
url = {https://arxiv.org/abs/1407.1731v2},
year = {2014}
}
