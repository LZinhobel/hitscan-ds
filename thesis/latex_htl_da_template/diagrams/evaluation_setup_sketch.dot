digraph G {
  layout=dot;
  rankdir=LR;
  graph [fontsize=12, fontname="Helvetica", labelloc="t", label="Evaluation Setup Sketch (Conceptual)"];
  node [fontname="Helvetica", fontsize=10, style="rounded,filled", color="#444444"];
  edge [color="#555555", arrowsize=0.8, fontname="Helvetica", fontsize=9];

  cam [shape=box, fillcolor="#e8f1ff", label="UGREEN Camera 4K\n1920x1080 @ 26 FPS"];
  angle [shape=box, fillcolor="#fff2df", label="Viewing angle\n~50 deg"];
  dist [shape=box, fillcolor="#fff2df", label="Distance\n~60 cm"];
  board [shape=circle, width=1.3, fixedsize=true, fillcolor="#f8f8f8", label="Dartboard"];
  ring [shape=ellipse, fillcolor="#fff9d6", label="Ring light\n(around board)"];
  detect [shape=box, fillcolor="#e9ffe9", label="Contour + tip detection\nstable under reduced shadows"];

  cam -> board [label="camera axis"];
  cam -> angle [style=dashed, arrowhead=none];
  cam -> dist [style=dashed, arrowhead=none];
  ring -> board [label="uniform illumination", dir=both];
  board -> detect;
}
